---
// Example portfolios strip. Data lives in src/data/examples.ts — add real artists
// there (with a `url` + `image`) and the cards become clickable thumbnails. Entries
// without a `url` fall back to a flat Bauhaus "canvas" with a primitive motif.
import { examples, hasRealExamples } from '../data/examples.ts';
---

<section class="section examples" id="examples">
  <div class="container">
    <h2>{hasRealExamples ? 'Portfolios made with Easel' : 'A few looks to start from'}</h2>
    <ul class="examples__grid" role="list">
      {examples.map((ex) => (
        <li class="examples__card">
          <Fragment>
            {ex.url ? (
              <a class="examples__link" href={ex.url} target="_blank" rel="noopener">
                <div class="examples__art" style={`--tint:${ex.tint}`} aria-hidden={ex.image ? undefined : 'true'}>
                  {ex.image ? <img src={ex.image} alt={`${ex.name}'s portfolio`} loading="lazy" class="examples__img" /> : <span class={`shape shape--${ex.shape}`}></span>}
                </div>
                <div class="examples__meta"><h3>{ex.name}</h3><p>{ex.medium}</p></div>
              </a>
            ) : (
              <Fragment>
                <div class="examples__art" style={`--tint:${ex.tint}`} aria-hidden="true">
                  <span class={`shape shape--${ex.shape}`}></span>
                </div>
                <div class="examples__meta"><h3>{ex.name}</h3><p>{ex.medium}</p></div>
              </Fragment>
            )}
          </Fragment>
        </li>
      ))}
    </ul>
    <p class="examples__note">
      {hasRealExamples
        ? 'Real sites, built by artists with no code. Yours will have your own work and name on it.'
        : 'These are just samples. Yours will have your own work and name on it.'}
    </p>
  </div>
</section>

<style>
  .examples__grid {
    list-style: none; margin: var(--space-5) 0 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .examples__card { border: var(--border-bold); background: var(--c-white); box-shadow: var(--shadow-hard); }
  .examples__link {
    display: block; text-decoration: none; color: inherit;
    transition: transform 120ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .examples__link:hover { transform: translate(-3px, -3px); }
  .examples__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .examples__art {
    aspect-ratio: 4 / 3;
    background:
      repeating-linear-gradient(0deg, transparent 0 28px, rgba(22,22,22,0.05) 28px 29px),
      var(--c-paper);
    display: grid; place-items: center;
    border-bottom: var(--border-bold);
  }
  .examples__art .shape--square,
  .examples__art .shape--circle { width: 88px; height: 88px; background: var(--tint); border: var(--border-bold); }
  .examples__art .shape--triangle { font-size: 92px; border-bottom-color: var(--tint); }
  .examples__meta { padding: var(--space-3) var(--space-4); }
  .examples__meta h3 { margin: 0 0 var(--space-1); }
  .examples__meta p { margin: 0; color: var(--c-stone); }
  .examples__note { margin-top: var(--space-4); color: var(--c-stone); }

  @media (max-width: 720px) {
    .examples__grid { margin-top: var(--space-4); gap: var(--space-3); }
    .examples__meta { padding: var(--space-3); }
  }
</style>

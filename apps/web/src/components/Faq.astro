---
const faqs = [
  {
    q: 'Do I need GitHub?',
    a: 'Yes — a free GitHub account is where your site lives. Easel connects to it for you in one click during setup, so you never have to learn git. If you do not have an account yet, GitHub will offer to make one during the connect step.',
  },
  {
    q: 'What does it cost?',
    a: 'Easel is free. Your site runs on the free tiers of GitHub and Netlify, both of which are plenty for an artist portfolio. There is no Easel subscription and no card required.',
  },
  {
    q: 'Can I use my own custom domain?',
    a: 'Yes. Your site is a normal Netlify site, so you can point a domain you own at it from Netlify any time — your-name.com instead of the default address. It is optional and you can add it later.',
  },
  {
    q: 'What happens to my site if I stop using Easel?',
    a: 'Nothing — it keeps running. Easel only sets things up; it never hosts your content. The GitHub repo and Netlify site are yours, so your portfolio stays live whether or not Easel does.',
  },
];
---

<section class="section faq" id="faq">
  <div class="container">
    <p class="eyebrow">Questions</p>
    <h2>Good things to know</h2>
    <div class="faq__list">
      {faqs.map((item) => (
        <details class="faq__item">
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__list {
    margin-top: var(--space-5);
    display: grid;
    gap: var(--space-3);
    max-width: 760px;
  }
  .faq__item {
    border: var(--border);
    background: var(--c-white);
  }
  .faq__item summary {
    cursor: pointer;
    list-style: none;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.125rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after {
    content: '+';
    font-size: 1.5rem;
    line-height: 1;
    color: var(--c-blue);
  }
  .faq__item[open] summary::after { content: '\2013'; }
  .faq__item p {
    padding: 0 var(--space-4) var(--space-4);
    margin: 0;
    color: var(--c-stone);
  }
</style>

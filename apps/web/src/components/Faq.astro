---
const faqs = [
  {
    q: 'What does Gesso cost?',
    a: "Absolutely nothing! Gesso provides a simple interface for you to use free web hosting services. For a better experience, you should buy a custom domain, which costs around $12 a year, but it's not required to use Gesso.",
  },
  {
    q: 'How can I trust Gesso to be free forever?',
    a: "Simple, we don't own or manage your site! Once you've set up your instance, you're in control of everything. Even if we started charging a subscription fee or set-up fee tomorrow, your site would remain completely yours.",
  },
  {
    q: 'What accounts do I need?',
    a: "You'll need a free GitHub account to store your site's files. GitHub offers free web hosting with GitHub Pages. If you prefer Netlify for hosting, you'll also need a separate Netlify account.",
  },
  {
    q: 'What prior coding knowledge do I need?',
    a: "None! Gesso uses a simple editor, and you'll never touch the code behind your site if you don't want to. If you have some experience, we support custom CSS and JavaScript snippets for making tweaks you want.",
  },
  {
    q: 'Can I use a custom domain?',
    a: "Absolutely! Custom domains are free on both GitHub Pages and Netlify. If you don't already have one, we suggest Porkbun as a no-frills registrar.",
  },
  {
    q: 'What generative AI defense tools does Gesso offer?',
    a: "Gesso wants you to have control over how your work is used, and offers no integrated AI features. Enabling llms.txt will tell web-crawlers to not use your data for training. Gesso also supports serving raw images run through Glaze and Nightshade.",
  },
  {
    q: 'I have an unanswered question or idea for a feature.',
    a: 'Awesome! Shoot us an email at <a href="mailto:hello@usegesso.com">hello@usegesso.com</a>.',
    html: true,
  },
];
---

<section class="section faq" id="faq">
  <div class="container">
    <h2>Questions?</h2>
    <div class="faq__list">
      {faqs.map((item) => (
        <details class="faq__item">
          <summary>{item.q}</summary>
          {item.html ? <p set:html={item.a} /> : <p>{item.a}</p>}
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__list {
    margin-top: var(--space-5);
    display: grid;
    gap: var(--space-3);
    max-width: 760px;
  }
  .faq__item {
    border: var(--border-bold);
    background: var(--c-white);
    box-shadow: var(--shadow-hard-sm);
  }
  .faq__item summary {
    cursor: pointer;
    list-style: none;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.125rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after {
    content: '+';
    font-size: 1.5rem;
    line-height: 1;
    color: var(--c-blue);
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Rotate the + into a × instead of swapping glyphs, so the marker turns smoothly. */
  .faq__item[open] summary::after { transform: rotate(45deg); }
  .faq__item p {
    padding: 0 var(--space-4) var(--space-4);
    margin: 0;
    color: var(--c-stone);
  }

  @media (prefers-reduced-motion: no-preference) {
    .faq__item[open] p {
      animation: faq-reveal 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes faq-reveal {
      from { opacity: 0; transform: translateY(-6px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }

  @media (max-width: 720px) {
    .faq__list { margin-top: var(--space-4); }
    /* Roomier tap targets for thumbs. */
    .faq__item summary {
      padding: var(--space-4) var(--space-3);
      font-size: 1.0625rem;
      gap: var(--space-3);
    }
    .faq__item p { padding: 0 var(--space-3) var(--space-4); }
  }
</style>

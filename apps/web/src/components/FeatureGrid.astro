---
// What you get — a numbered editorial composition on a yellow field, not a grid
// of identical cards. Big index numerals + one large primitive anchor each row.
const features = [
  {
    shape: 'square',
    title: 'Drag your work in',
    body: "Upload right in the editor, give each piece a title, and you're done. No spreadsheets, no fuss.",
  },
  {
    shape: 'circle',
    title: 'Hosting you own, free',
    body: "Publish to GitHub Pages or Netlify. Either way, the site lives on an account you own. Gesso handles setup once, then it's all yours.",
  },
  {
    shape: 'triangle',
    title: 'Made to be seen',
    body: 'A clean, gallery-first layout that loads fast and looks great on a phone or a wide screen.',
  },
  {
    shape: 'square',
    title: 'No code, ever',
    body: "You'll never touch git, builds, or config files. Publishing feels as easy as any notes app you already use.",
  },
];
---

<section class="section features band--paper">
  <div class="container">
    <h2>Built for showing your work</h2>
    <ol class="features__list" role="list">
      {features.map((f, i) => (
        <li class="feature">
          <span class="feature__num">{String(i + 1).padStart(2, '0')}</span>
          <span class={`shape shape--${f.shape} feature__glyph`} aria-hidden="true"></span>
          <div class="feature__body">
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .features__list {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
  }
  .feature {
    display: grid;
    grid-template-columns: clamp(3rem, 7vw, 5.5rem) 72px minmax(0, 1fr);
    gap: var(--space-5);
    align-items: center;
    padding-block: var(--space-4);
    border-top: var(--border-bold);
  }

  /* Subtle staggered pop-in as each row scrolls into view. Only armed once JS
     adds .js-reveal (so no-JS keeps every row visible), and skipped entirely
     under reduced-motion. */
  @media (prefers-reduced-motion: no-preference) {
    .features.js-reveal .feature {
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: calc(var(--i, 0) * 70ms);
    }
    .features.js-reveal .feature.is-in {
      opacity: 1;
      transform: none;
    }
  }
  .feature:last-child { border-bottom: var(--border-bold); }

  .feature__num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    line-height: 1;
    color: var(--c-ink);
  }

  .feature__glyph {
    width: 72px;
    height: 72px;
    border: var(--border-bold);
  }
  /* The glyph's box border would smother a triangle, so it's rebuilt from
     borders and given the hard offset shadow for presence on the paper field. */
  .feature .shape--triangle {
    width: 0; height: 0;
    border-left: 40px solid transparent;
    border-right: 40px solid transparent;
    border-bottom: 72px solid var(--c-yellow);
    border-top: 0;
    box-shadow: none;
    filter: drop-shadow(4px 4px 0 var(--c-ink));
  }

  .feature__body h3 { margin: 0 0 var(--space-1); }
  .feature__body p { margin: 0; color: var(--c-ink); max-width: 60ch; }

  @media (max-width: 720px) {
    .feature {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        'num glyph'
        'body body';
      gap: var(--space-3) var(--space-4);
      align-items: center;
      padding-block: var(--space-4);
    }
    .feature__num { grid-area: num; }
    .feature__glyph { grid-area: glyph; justify-self: start; width: 56px; height: 56px; }
    .feature .shape--triangle {
      width: 0; height: 0;
      border-left: 32px solid transparent;
      border-right: 32px solid transparent;
      border-bottom: 56px solid var(--c-yellow);
    }
    .feature__body { grid-area: body; }
  }
</style>

<script>
  // Reveal feature rows as they scroll in — a small, staggered pop. Progressive
  // enhancement: without this script the rows are simply always visible.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const section = document.querySelector<HTMLElement>('.features');
  if (section && !reduce && 'IntersectionObserver' in window) {
    const rows = Array.from(section.querySelectorAll<HTMLElement>('.feature'));
    rows.forEach((row, i) => row.style.setProperty('--i', String(i)));
    section.classList.add('js-reveal');
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.25, rootMargin: '0px 0px -8% 0px' }
    );
    rows.forEach((row) => io.observe(row));
  }
</script>

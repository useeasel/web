---
// Feature blocks. Each gets one of the three Bauhaus primitives as its glyph.
const features = [
  {
    shape: 'square',
    title: 'Drag your photos in',
    body: 'Upload your work right in the editor. Give a piece a title, set a price, mark it sold when it goes. No spreadsheets to keep up.',
  },
  {
    shape: 'circle',
    title: 'Your own Netlify, free',
    body: 'Your site lives on a Netlify account you own and control. Easel does the setup once, and after that it belongs to you.',
  },
  {
    shape: 'triangle',
    title: 'Made to be seen',
    body: 'A clean, gallery-first layout that loads fast and looks right on a phone or a wide screen. Built on Astro.',
  },
  {
    shape: 'square',
    title: 'No code, ever',
    body: 'You never see git, builds, or config files. Writing and publishing feels like any notes app you already use.',
  },
];
---

<section class="section features">
  <div class="container">
    <p class="eyebrow">What you get</p>
    <h2>Built for showing your work</h2>
    <ul class="features__grid" role="list">
      {features.map((f) => (
        <li class="card feature">
          <span class={`shape shape--${f.shape} feature__glyph`} aria-hidden="true"></span>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .features__grid {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .feature { display: flex; flex-direction: column; }
  .feature__glyph {
    width: 40px;
    height: 40px;
    margin-bottom: var(--space-3);
  }
  .feature .shape--triangle {
    width: 0; height: 0; font-size: 40px;
  }
  .feature p { margin: 0; color: var(--c-stone); }
</style>

---
import EaselMark from './EaselMark.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand" href="/" aria-label="Easel home">
        <EaselMark size={30} />
        <span class="brand__word">Easel</span>
      </a>
      <p class="site-footer__tag">Portfolio sites for artists. Free, fast, and yours.</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <div>
        <h4>Product</h4>
        <a href="/how-it-works/">How it works</a>
        <a href="/start/">Start free</a>
        <a href="/#examples">Examples</a>
      </div>
      <div>
        <h4>Help</h4>
        <a href="/#faq">FAQ</a>
        <a href="https://github.com/useeasel" rel="noopener">GitHub</a>
      </div>
    </nav>
  </div>
  <div class="container site-footer__base">
    <span>&copy; {year} Easel</span>
    <span class="site-footer__shapes" aria-hidden="true">
      <span class="shape shape--square"></span>
      <span class="shape shape--circle"></span>
      <span class="shape shape--triangle"></span>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border);
    background: var(--c-ink);
    color: var(--c-paper);
    margin-top: var(--space-7);
  }
  .site-footer a { color: var(--c-paper); text-decoration: none; }
  .site-footer a:hover { color: var(--c-yellow); }
  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-6) var(--space-4);
    flex-wrap: wrap;
  }
  .site-footer .brand__word { color: var(--c-paper); font-family: var(--font-display); font-weight: 800; font-size: 1.5rem; }
  .site-footer .brand { display: inline-flex; align-items: center; gap: var(--space-2); }
  .site-footer__tag { color: var(--c-stone); max-width: 32ch; margin-top: var(--space-3); }
  .site-footer__nav { display: flex; gap: var(--space-6); }
  .site-footer__nav h4 { font-family: var(--font-display); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--c-stone); margin-bottom: var(--space-2); }
  .site-footer__nav div { display: flex; flex-direction: column; gap: var(--space-2); }
  .site-footer__base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4);
    border-top: 2px solid var(--c-stone);
    font-size: 0.875rem;
    color: var(--c-stone);
  }
  .site-footer__shapes { display: inline-flex; gap: var(--space-2); align-items: center; }
  .site-footer__shapes .shape--square,
  .site-footer__shapes .shape--circle { width: 14px; height: 14px; }
  .site-footer__shapes .shape--triangle { font-size: 14px; }
</style>

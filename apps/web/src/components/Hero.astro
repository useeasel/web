---
interface Props {
  headline?: string;
  sub?: string;
}
const {
  headline = "An online portfolio that's truly yours.",
  sub = "Gesso is a no-code portfolio site creator for artists of all practices. It's customizable, accessible, and free forever.",
} = Astro.props;

// Decorative demo shown in the hero browser — a stand-in artist site that types
// its own domain and then fills in. Purely illustrative (aria-hidden).
const demoDomain = 'maya-okonkwo.art';
const demoName = 'maya okonkwo';
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <h1>{headline}</h1>
      <p class="hero__sub">{sub}</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/start/">Start free</a>
        <a class="btn hero__see" href="/how-it-works/">See how it works</a>
      </div>
      <p class="hero__note">No credit card, no code, and your site stays yours. Live in ten minutes.</p>
    </div>

    <div class="hero__art" aria-hidden="true">
      <div class="bw">
        <div class="bw__top">
          <span class="bw__dot" style="background: var(--c-red)"></span>
          <span class="bw__dot" style="background: var(--c-yellow)"></span>
          <span class="bw__dot" style="background: var(--c-blue)"></span>
          <span class="bw__url" data-type={demoDomain}><span class="bw__caret">&nbsp;</span></span>
        </div>
        <div class="bw__body" data-fill>
          <div class="bw__banner"><span>{demoName}</span></div>
          <span class="bw__cell" style="background: var(--c-yellow)"></span>
          <span class="bw__cell" style="background: var(--c-red)"></span>
          <span class="bw__cell" style="background: var(--c-blue)"></span>
          <span class="bw__cell" style="background: var(--c-white)"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- All-black marquee: the graphic border between the hero and "Built for
     showing your work". Decorative, so hidden from assistive tech. -->
<div class="hero-divider" aria-hidden="true">
  <div class="hero-divider__track">
    <div class="hero-divider__group">
      <span>truly yours</span><span class="hd-sq"></span>
      <span>no code</span><span class="hd-ci"></span>
      <span>free forever</span><span class="hd-tr"></span>
      <span>drag photos in</span><span class="hd-sq"></span>
      <span>live in ten minutes</span><span class="hd-ci"></span>
    </div>
    <div class="hero-divider__group">
      <span>truly yours</span><span class="hd-sq"></span>
      <span>no code</span><span class="hd-ci"></span>
      <span>free forever</span><span class="hd-tr"></span>
      <span>drag photos in</span><span class="hd-sq"></span>
      <span>live in ten minutes</span><span class="hd-ci"></span>
    </div>
  </div>
</div>

<style>
  /* Neon-yellow field. The hero owns the loud colour; the marquee divider below
     hands off to the calmer paper "Built for showing your work" section. */
  .hero {
    background: var(--c-yellow);
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-6);
    align-items: center;
    padding-block: var(--space-6);
  }
  /* Scoped smaller than the global h1 so the headline lands in three lines. */
  .hero h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); }
  .hero__sub {
    font-size: 1.25rem;
    line-height: 1.45;
    max-width: 40ch;
    color: var(--c-ink);
  }
  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-block: var(--space-5) var(--space-3);
  }
  /* Stone reads muddy on yellow — ink at reduced opacity keeps it AA. */
  .hero__note {
    color: var(--c-ink);
    opacity: 0.72;
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0;
  }

  /* ---- The live-site browser (types its domain, then fills in) ---- */
  .bw {
    border: var(--border-thick);
    background: var(--c-white);
    box-shadow: var(--shadow-hard);
  }
  .bw__top {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: var(--border-bold);
    background: var(--c-paper);
  }
  .bw__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--c-ink);
    flex: none;
  }
  .bw__url {
    flex: 1;
    min-width: 0;
    background: var(--c-white);
    border: var(--border);
    padding: 4px 12px;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
  }
  .bw__caret {
    display: inline-block;
    width: 2px;
    background: var(--c-ink);
  }
  @media (prefers-reduced-motion: no-preference) {
    .bw__caret { animation: bw-blink 1s steps(1) infinite; }
  }
  @keyframes bw-blink { 50% { opacity: 0; } }
  .bw__body {
    padding: var(--space-4);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  /* Holds at opacity 0 until the URL finishes typing (JS adds .is-filled). With
     no JS / reduced motion the body is shown immediately (see below). */
  @media (prefers-reduced-motion: no-preference) {
    .bw__body { opacity: 0; }
    .bw__body.is-filled { animation: bw-fade 0.6s ease both; }
  }
  @keyframes bw-fade {
    from { opacity: 0; translate: 0 10px; }
    to { opacity: 1; translate: 0 0; }
  }
  .bw__banner {
    grid-column: 1 / 3;
    height: 90px;
    background: var(--c-blue);
    border: var(--border-bold);
    display: flex;
    align-items: center;
    padding-inline: 16px;
  }
  .bw__banner span {
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--c-white);
    font-size: 1.35rem;
  }
  .bw__cell {
    height: 64px;
    border: var(--border-bold);
  }

  /* Copy rises on load. */
  @media (prefers-reduced-motion: no-preference) {
    .hero__copy > * { animation: hero-rise 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .hero__copy > *:nth-child(1) { animation-delay: 0.04s; }
    .hero__copy > *:nth-child(2) { animation-delay: 0.10s; }
    .hero__copy > *:nth-child(3) { animation-delay: 0.18s; }
    .hero__copy > *:nth-child(4) { animation-delay: 0.26s; }
  }
  @keyframes hero-rise {
    from { opacity: 0; translate: 0 18px; }
    to { opacity: 1; translate: 0 0; }
  }

  /* ---- All-black marquee divider ---- */
  .hero-divider {
    background: var(--c-ink);
    color: var(--c-paper);
    border-block: var(--border-thick);
    overflow: hidden;
    display: flex;
  }
  .hero-divider__track {
    display: flex;
    flex: none;
    white-space: nowrap;
    align-items: center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-divider__track { animation: hero-marquee 26s linear infinite; }
  }
  @keyframes hero-marquee { to { transform: translateX(-50%); } }
  .hero-divider__group {
    flex: none;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: lowercase;
    font-size: 1.9rem;
    padding-block: 0.55rem;
  }
  .hero-divider__group > span:not([class]) { padding-inline: 1.3rem; }
  .hd-sq, .hd-ci, .hd-tr { flex: none; color: var(--c-yellow); }
  .hd-sq { width: 1em; height: 1em; border: 2px solid currentColor; }
  .hd-ci { width: 1em; height: 1em; border-radius: 50%; border: 2px solid currentColor; }
  .hd-tr {
    width: 0; height: 0;
    border-left: 0.6em solid transparent;
    border-right: 0.6em solid transparent;
    border-bottom: 1em solid currentColor;
  }

  /* ---- Mobile: stack, lead with the browser ---- */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .hero__art { order: -1; }
  }

  @media (max-width: 540px) {
    .hero__inner { padding-block: var(--space-5); }
    .hero__sub { font-size: 1.125rem; }
    .hero__actions {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-3);
    }
    /* One dominant action: primary stays a full-width button, "See how it
       works" demotes to a quiet centered link. */
    .hero__actions .btn--primary {
      width: 100%;
      justify-content: center;
      padding-block: 0.9rem;
    }
    .hero__see {
      border: none;
      background: transparent;
      box-shadow: none;
      padding: var(--space-1) 0;
      align-self: center;
      text-decoration: underline;
      text-underline-offset: 4px;
    }
    .hero__see:hover { transform: none; box-shadow: none; color: var(--c-blue); }
    .hero-divider__group { font-size: 1.5rem; }
  }
</style>

<script>
  // Type the demo domain, then reveal the site body. Loops gently. Honours
  // reduced-motion by showing the finished state with no animation.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll<HTMLElement>('.hero [data-type]').forEach((el) => {
    const full = el.dataset.type ?? '';
    const caret = el.querySelector('.bw__caret');
    const body = el.closest('.bw')?.querySelector<HTMLElement>('[data-fill]');
    const textNode = document.createTextNode('');
    if (caret) el.insertBefore(textNode, caret);

    const run = () => {
      let i = 0;
      body?.classList.remove('is-filled');
      textNode.nodeValue = '';
      if (reduce) {
        textNode.nodeValue = full;
        body?.classList.add('is-filled');
        return;
      }
      const iv = window.setInterval(() => {
        textNode.nodeValue = full.slice(0, ++i);
        if (i >= full.length) {
          window.clearInterval(iv);
          window.setTimeout(() => body?.classList.add('is-filled'), 250);
        }
      }, 95);
    };

    run();
    if (!reduce) window.setInterval(run, 7000);
  });
</script>

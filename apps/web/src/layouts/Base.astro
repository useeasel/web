---
import '@fontsource-variable/jost';
import '@fontsource-variable/hanken-grotesk';
import '../styles/tokens.css';
import Footer from '../components/Footer.astro';
import GessoMark from '../components/GessoMark.astro';

interface Props {
  title?: string;
  description?: string;
  /** Social-card image, resolved against the site origin. Defaults to /og.png. */
  image?: string;
  /** Per-page JSON-LD structured data, appended to the site-wide graph. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Gesso · an online portfolio that's truly yours",
  description = "A no-code portfolio site creator for artists. Customizable, accessible, and free forever.",
  image = '/og.png',
  jsonLd,
} = Astro.props;

// Resolve absolute URLs for canonical + social tags (crawlers want fully-qualified
// URLs). Astro.site is set to https://usegesso.com in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// Site-wide structured data: who Gesso is, plus the site itself for search. Pages
// can pass extra `jsonLd` (e.g. the SoftwareApplication graph on the homepage).
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Gesso',
    url: 'https://usegesso.com',
    logo: 'https://usegesso.com/og.png',
    description:
      'A no-code portfolio site creator for artists. Customizable, accessible, and free forever.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Gesso',
    url: 'https://usegesso.com',
  },
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Gesso — an online portfolio that's truly yours" />
    <meta property="og:site_name" content="Gesso" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {
      structuredData.map((data) => (
        <script type="application/ld+json" set:html={JSON.stringify(data)} />
      ))
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/" aria-label="Gesso home">
          <GessoMark size={34} />
          <span class="brand__word">gesso</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/how-it-works/">How it works</a>
          <a href="/#own">Own it</a>
          <a href="/#faq">FAQ</a>
          <a class="btn btn--primary site-nav__cta" href="/start/">Start free</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <Footer />

    <style>
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--c-ink);
        color: var(--c-white);
        padding: var(--space-2) var(--space-3);
        z-index: 100;
      }
      .skip-link:focus { left: var(--space-3); top: var(--space-3); }

      .site-header {
        border-bottom: var(--border-bold);
        background: var(--c-paper);
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: var(--space-3);
        gap: var(--space-4);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        text-decoration: none;
        color: var(--c-ink);
      }
      .brand__word {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 1.5rem;
        letter-spacing: -0.02em;
        /* "gesso" is all-lowercase with no ascenders + a descender, so its ink
           sits low in the line box against the top-heavy mark. Nudge it up to
           seat the wordmark's optical centre on the mark's mass. */
        transform: translateY(-0.15em);
      }
      .site-nav {
        display: flex;
        align-items: center;
        gap: var(--space-4);
      }
      .site-nav a {
        font-family: var(--font-display);
        font-weight: 600;
        text-transform: lowercase;
        text-decoration: none;
      }
      /* Exclude the button so its own (white-on-blue) colour isn't overridden by
         the nav link colour/hover — that override is what made the CTA text turn
         blue on hover and vanish against its background. */
      .site-nav a:not(.site-nav__cta) { color: var(--c-ink); }
      .site-nav a:not(.site-nav__cta):hover { color: var(--c-blue); }
      .site-nav__cta { color: var(--c-white); }

      @media (max-width: 720px) {
        .site-nav a:not(.site-nav__cta) { display: none; }
        /* Shorter sticky bar so it doesn't eat the small viewport. */
        .site-header__inner { padding-block: var(--space-2); }
        .brand__word { font-size: 1.25rem; }
        .site-nav__cta { padding: 0.55rem 1.1rem; }
      }
    </style>
  </body>
</html>

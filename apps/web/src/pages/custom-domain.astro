---
import Base from '../layouts/Base.astro';

// Custom-domain walkthrough. Pointing a domain is the one post-setup task Gesso
// can't do for the artist (we never touch DNS — the domain lives in their own
// registrar + host accounts). This page is the friendly, end-to-end version of the
// one-liner on /own-your-site. If we have a deploy cookie from /start/done, the
// callout + step links deep-link straight into *their* host, and we show the step
// set that matches the host they published to (Netlify or GitHub Pages).

const getDomain = {
  title: 'Get a domain name',
  body: 'If you don\'t already own one, buy a domain from a registrar like Cloudflare, Namecheap, or Porkbun. It costs about $10–15 a year. You buy it directly, so it\'s yours. Gesso and your host never sell you the domain or lock it up. Already have one? Skip ahead.',
};

// Two host-specific step sets. The client shows whichever matches the deploy cookie
// (defaulting to Netlify for older records that predate the host field).
const stepsByHost: Record<'netlify' | 'github-pages', { title: string; body: string }[]> = {
  netlify: [
    getDomain,
    {
      title: 'Open your site\'s domain settings in Netlify',
      body: 'In Netlify, open your site and go to **Domain management**. That\'s where every domain change for your site happens. (If you set up with Gesso, the button below jumps straight there.)',
    },
    {
      title: 'Add your domain',
      body: 'Click **Add a domain**, type your address (e.g. `your-name.com`), and confirm. Netlify will check it and add it to your site. You can add both the bare `your-name.com` and the `www.` version.',
    },
    {
      title: 'Point your domain at Netlify',
      body: 'The easiest path is to let **Netlify manage your DNS**: it shows you four nameservers. Set those at your registrar (replacing the ones already there) and Netlify handles the rest. Prefer to keep your registrar\'s DNS? Netlify instead shows the exact records to add (an A or ALIAS record for the bare domain, a CNAME for `www`).',
    },
    {
      title: 'Wait for it to go live',
      body: 'DNS changes take a few minutes to a few hours to spread across the internet. This is normal. Once Netlify sees your domain pointing the right way, it provisions a free HTTPS certificate, so your site loads securely.',
    },
    {
      title: 'Make it your primary domain',
      body: 'Optional but tidy: in Domain management, set your custom domain as the **primary** one. Visitors who land on the old `*.netlify.app` address are then redirected to your real domain.',
    },
  ],
  'github-pages': [
    getDomain,
    {
      title: 'Open your repository\'s Pages settings',
      body: 'On GitHub, open your repository, then go to **Settings → Pages**. That\'s where the custom domain for your site is set. (If you set up with Gesso, the button below jumps straight there.)',
    },
    {
      title: 'Add your domain',
      body: 'Under **Custom domain**, type your address (e.g. `your-name.com`) and click **Save**. GitHub adds a `CNAME` file to your repository and starts checking the domain.',
    },
    {
      title: 'Point your domain at GitHub Pages',
      body: 'At your registrar, add a `CNAME` record for **www** pointing to `your-username.github.io`. For the bare `your-name.com`, add the four GitHub **A records** (`185.199.108.153`, `185.199.109.153`, `185.199.110.153`, `185.199.111.153`). Or use an `ALIAS`/`ANAME` to `your-username.github.io` if your registrar supports it.',
    },
    {
      title: 'Wait for it, then turn on HTTPS',
      body: 'DNS changes take a few minutes to a few hours to spread. This is normal. Once GitHub shows the domain as verified, tick **Enforce HTTPS** on the same Pages settings page, and GitHub provisions a free certificate so your site loads securely.',
    },
  ],
};

const md = (s: string) =>
  s
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
---

<Base
  title="Add a custom domain · Gesso"
  description="A step-by-step guide to pointing your own domain (like your-name.com) at your Gesso portfolio, whether it's hosted on Netlify or GitHub Pages. Gesso never touches your DNS, so your domain stays yours."
>
  <section class="section domain-hero">
    <div class="container">
      <h1>Add your own domain</h1>
      <p class="domain-hero__sub">
        Give your portfolio a real address like <strong>your-name.com</strong>. Your domain
        lives in your own registrar and host accounts, and Gesso never touches your DNS.
        The whole process, start to finish.
      </p>

      <div id="domain-welcome" class="domain-welcome" hidden>
        <p class="domain-welcome__line">
          Your Gesso site <strong id="domain-welcome-slug"></strong> went live
          <span id="domain-welcome-when"></span>. Pick up right where you left off:
        </p>
        <a id="domain-welcome-link" class="btn btn--accent" href="#" target="_blank" rel="noopener">
          Open your domain management
        </a>
      </div>
    </div>
  </section>

  <section class="section domain-steps">
    <div class="container">
      {Object.entries(stepsByHost).map(([host, steps]) => (
        <ol class="domain-steps__list" role="list" data-host={host} hidden={host !== 'netlify'}>
          {steps.map((s, i) => (
            <li class="domain-step">
              <span class="domain-step__num" aria-hidden="true">{i + 1}</span>
              <div>
                <h2>{s.title}</h2>
                <p set:html={md(s.body)} />
                {i === 1 && (
                  <p class="domain-step__deep">
                    <a class="domain-deeplink" data-host={host}
                      href={host === 'github-pages' ? 'https://github.com/' : 'https://app.netlify.com/'}
                      target="_blank" rel="noopener">
                      {host === 'github-pages' ? 'Open your GitHub Pages settings →' : 'Open Netlify domain management →'}
                    </a>
                  </p>
                )}
              </div>
            </li>
          ))}
        </ol>
      ))}

      <p class="domain-steps__note" id="domain-docs-netlify">
        Stuck on a specific record or registrar? Netlify's
        <a href="https://docs.netlify.com/domains-https/custom-domains/" target="_blank" rel="noopener">custom domain docs</a>
        cover the edge cases. And because your domain never depends on Gesso, you can change or
        move it any time without us.
      </p>
      <p class="domain-steps__note" id="domain-docs-github-pages" hidden>
        Stuck on a specific record or registrar? GitHub's
        <a href="https://docs.github.com/pages/configuring-a-custom-domain-for-your-github-pages-site" target="_blank" rel="noopener">custom domain docs</a>
        cover the edge cases. And because your domain never depends on Gesso, you can change or
        move it any time without us.
      </p>
    </div>
  </section>
</Base>

<script>
  import { domainSetupUrl, readDeploy } from '../deploy';

  // If the artist provisioned through Gesso, show the step set for *their* host,
  // deep-link straight into it, and greet them by site + date.
  const rec = readDeploy();
  const provider = rec?.provider === 'github-pages' ? 'github-pages' : 'netlify';

  // Reveal the matching step list + docs note, hide the other.
  document.querySelectorAll<HTMLElement>('.domain-steps__list').forEach((ol) => {
    ol.toggleAttribute('hidden', ol.dataset.host !== provider);
  });
  document
    .querySelector<HTMLElement>('#domain-docs-netlify')
    ?.toggleAttribute('hidden', provider !== 'netlify');
  document
    .querySelector<HTMLElement>('#domain-docs-github-pages')
    ?.toggleAttribute('hidden', provider !== 'github-pages');

  if (rec) {
    const url = domainSetupUrl(rec) ?? '#';
    document
      .querySelector<HTMLAnchorElement>(`.domain-deeplink[data-host="${provider}"]`)
      ?.setAttribute('href', url);

    const slug =
      provider === 'github-pages' ? (rec.repo ? rec.repo.split('/').pop() ?? null : null) : (rec.netlify ?? null);

    const welcome = document.querySelector<HTMLElement>('#domain-welcome');
    const slugEl = document.querySelector<HTMLElement>('#domain-welcome-slug');
    const whenEl = document.querySelector<HTMLElement>('#domain-welcome-when');
    const link = document.querySelector<HTMLAnchorElement>('#domain-welcome-link');

    if (slugEl) slugEl.textContent = slug ?? 'your site';
    if (whenEl && rec.at) {
      const d = new Date(rec.at);
      if (!Number.isNaN(d.getTime())) {
        whenEl.textContent = `on ${d.toLocaleDateString(undefined, {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}`;
      }
    }
    if (link) {
      link.href = url;
      link.textContent =
        provider === 'github-pages' ? 'Open your GitHub Pages settings' : 'Open your domain management';
    }
    welcome?.removeAttribute('hidden');
  }
</script>

<style>
  .domain-hero { border-bottom: var(--border); }
  .domain-hero__sub { font-size: 1.25rem; max-width: 56ch; }

  .domain-welcome {
    margin-top: var(--space-5);
    max-width: 640px;
    border: var(--border);
    border-left: var(--border-thick);
    border-left-color: var(--c-blue);
    background: var(--c-white);
    padding: var(--space-4);
  }
  .domain-welcome__line { margin: 0 0 var(--space-3); color: var(--c-ink); }

  .domain-steps__list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-5); max-width: 760px; }
  .domain-step { display: flex; gap: var(--space-4); align-items: flex-start; }
  .domain-step__num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 52px; height: 52px; flex: none;
    font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;
    color: var(--c-white); background: var(--c-blue); border: var(--border);
  }
  .domain-step h2 { font-size: 1.375rem; margin-bottom: var(--space-2); }
  .domain-step p { margin: 0; color: var(--c-stone); }
  .domain-step__deep { margin-top: var(--space-2) !important; }
  .domain-step__deep a { font-family: var(--font-display); font-weight: 700; color: var(--c-blue); }
  .domain-step code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: var(--c-paper);
    border: 1px solid var(--c-stone);
    padding: 0.05em 0.3em;
  }
  .domain-steps__note {
    margin-top: var(--space-6);
    max-width: 760px;
    border-left: var(--border-thick);
    padding-left: var(--space-3);
    color: var(--c-stone);
  }
</style>

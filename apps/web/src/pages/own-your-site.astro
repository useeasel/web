---
import Base from '../layouts/Base.astro';

// "Take it with you" guide. Gesso's promise is that the artist owns their site;
// this page makes that tangible — what the repo is, how to move hosts, how to hand
// it to a developer. Custom domains are explicitly a host task (Gesso never
// manages DNS), so we point there rather than pretending to do it in-app.

const moves = [
  {
    title: 'See everything that makes up your site',
    body: 'Your GitHub repository holds it all: every image lives in `src/assets`, every page and artwork is a plain text file in `src/content`, and your design choices are one `settings.json`. Nothing is trapped in a database only Gesso can read.',
  },
  {
    title: 'Add a custom domain',
    body: 'Your host, GitHub Pages or Netlify, handles your domain. Gesso never touches DNS. Our [step-by-step domain guide](/custom-domain/) walks you through pointing your domain (e.g. your-name.com) at the site, and your host sets up HTTPS for you.',
  },
  {
    title: 'Move to a different host',
    body: 'Because your site is a standard Astro project, any static host (GitHub Pages, Netlify, Cloudflare Pages, your own server) can build it. Point the host at your GitHub repo, set the build command to `astro build` and the output directory to `dist`, and you\'re live elsewhere. No Gesso involved.',
  },
  {
    title: 'Hand it to a developer',
    body: 'Give them access to your GitHub repository. It\'s a normal, well-structured codebase they can read, extend, or restyle. Your content and their changes live side by side in version history.',
  },
];
---

<Base
  title="Own your site · Gesso"
  description="Your Gesso portfolio lives in your own GitHub repository. Add a domain, move hosts, or hand it to a developer. Any time, no lock-in."
>
  <section class="section own-hero">
    <div class="container">
      <h1>Own your site, for real</h1>
      <p class="own-hero__sub">
        Gesso sets your portfolio up and then steps out. Everything lives on accounts you
        control, so you can take it anywhere.
      </p>
    </div>
  </section>

  <section class="section own-moves">
    <div class="container">
      <ol class="own-moves__list" role="list">
        {moves.map((m, i) => (
          <li class="own-move">
            <span class="own-move__num" aria-hidden="true">{i + 1}</span>
            <div>
              <h2>{m.title}</h2>
              <p set:html={m.body
                .replace(/`([^`]+)`/g, '<code>$1</code>')
                .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')} />
            </div>
          </li>
        ))}
      </ol>

    </div>
  </section>

  <section class="section permanence band--paper">
    <div class="container">
      <h2 class="permanence__title">If Gesso vanished tomorrow</h2>
      <p class="permanence__lead">Your site would keep running, with nothing to move and nothing to fix. Here is exactly why.</p>
      <ul class="permanence__grid" role="list">
        <li class="permanence__card">
          <span class="permanence__tag">Your repository</span>
          <p>The whole site sits in a GitHub repo on your account. Gesso only had permission while you were connected; revoke it and the repo is still entirely yours.</p>
        </li>
        <li class="permanence__card">
          <span class="permanence__tag">Your files</span>
          <p>Every page and artwork is a plain text file, every image a normal image. Open them in any editor. Nothing is locked in a format only we can read.</p>
        </li>
        <li class="permanence__card">
          <span class="permanence__tag">Your host</span>
          <p>GitHub Pages or Netlify builds and serves the site straight from your repo. That build runs without us, on every change, forever.</p>
        </li>
        <li class="permanence__card">
          <span class="permanence__tag">Your domain</span>
          <p>Your domain is set up at your own host and registrar. Gesso never touches it, so it points where you say no matter what happens to us.</p>
        </li>
      </ul>
      <p class="permanence__kicker">Gesso runs the one-time setup, then steps out. After that, taking Gesso away changes nothing about your live site.</p>
    </div>
  </section>
</Base>

<style>
  .own-hero { border-bottom: var(--border); }
  .own-hero__sub { font-size: 1.25rem; max-width: 52ch; }

  .own-moves__list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-5); max-width: 760px; }
  .own-move { display: flex; gap: var(--space-4); align-items: flex-start; }
  .own-move__num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 52px; height: 52px; flex: none;
    font-family: var(--font-display); font-weight: 800; font-size: 1.5rem;
    color: var(--c-white); background: var(--c-blue); border: var(--border);
  }
  .own-move h2 { font-size: 1.375rem; margin-bottom: var(--space-2); }
  .own-move p { margin: 0; color: var(--c-stone); }
  .own-move code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: var(--c-paper);
    border: 1px solid var(--c-stone);
    padding: 0.05em 0.3em;
  }
  .permanence { border-top: var(--border); }
  .permanence__title { font-size: 1.75rem; }
  .permanence__lead { max-width: 60ch; color: var(--c-stone); margin-bottom: var(--space-5); }
  .permanence__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: var(--space-4);
  }
  .permanence__card {
    border: var(--border);
    background: var(--c-white);
    padding: var(--space-4);
  }
  .permanence__card p { margin: var(--space-2) 0 0; color: var(--c-stone); }
  .permanence__tag {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.8rem;
    color: var(--c-white);
    background: var(--c-blue);
    padding: 0.15em 0.5em;
  }
  .permanence__kicker {
    margin-top: var(--space-5);
    max-width: 760px;
    border-left: var(--border-thick);
    padding-left: var(--space-3);
    font-weight: 700;
  }
</style>

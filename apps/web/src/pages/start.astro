---
import Base from '../layouts/Base.astro';
import ConnectStep from '../components/ConnectStep.astro';
import ProgressView from '../components/ProgressView.astro';
import { ROUTES } from '../config.ts';

// The onboarding flow.
//
// This page is static HTML; the client script below drives the multi-step state
// machine. Each connect button is a link to a route on the provisioning Worker
// (workers/provision). After GitHub OAuth, the worker redirects back here with
// ?step=netlify&state=...; after Netlify OAuth, with ?step=provision&state=...
//
// IMPORTANT: the worker implements /auth/github, /auth/netlify, and /provision.
// Those endpoints handle the OAuth dance and store transient tokens in KV keyed
// by the signed `state`. This page only ever holds the opaque `state` value.
---

<Base title="Start your portfolio · Easel" description="Connect GitHub and Netlify, name your site, and Easel builds your portfolio.">
  <section class="section start">
    <div class="container start__inner">
      <header class="start__head">
        <h1>Let's build your portfolio</h1>
        <p class="start__sub">
          Three short steps. You'll connect two free accounts, then Easel does the rest.
          Nothing is charged, and we don't host a thing.
        </p>
        <p id="start-over-wrap" class="start__over" hidden>
          Connected the wrong account? <button type="button" id="btn-start-over" class="linklike">Start over</button>.
        </p>
        <p id="connect-error" class="start__error" role="alert" hidden></p>
      </header>

      <ConnectStep step={1} title="Connect GitHub" state="active" shape="square">
        <p>
          <abbr class="hint" title="A very popular, free platform for hosting code. It's where your site's files will live.">GitHub</abbr>
          is where the backend code and edit history for your site will live. You'll also use
          it to log in to your site's editor. Don't worry, you won't need to touch any code!
        </p>
        <div class="start__actions" id="github-actions">
          <a id="btn-github" class="btn btn--primary" href={ROUTES.authGithub}>
            Connect GitHub
          </a>
          <a class="btn btn--ghost" href="https://github.com/signup" target="_blank" rel="noopener">
            Create a GitHub account
          </a>
        </div>
        <p id="github-connected" class="start__connected" hidden>
          <span class="start__check" aria-hidden="true"></span>GitHub connected<span id="github-login"></span>.
        </p>
        <p class="start__hint">No account yet? Create one for free, then come back here to connect.</p>
      </ConnectStep>

      <ConnectStep step={2} title="Choose where to publish" state="todo" shape="circle">
        <p>
          Pick where your site goes live. Both are free, and either way the site stays
          entirely yours — Easel never hosts a thing.
        </p>
        <fieldset class="host-picker" id="host-picker">
          <legend class="start__visually-hidden">Hosting provider</legend>
          <label class="host-option">
            <input type="radio" name="host" value="github-pages" checked />
            <span class="host-option__body">
              <span class="host-option__name">GitHub Pages <span class="host-option__tag">Recommended</span></span>
              <span class="host-option__desc">
                Publishes straight from the GitHub account you just connected — no extra
                sign-up. Free, with free custom domains. Your contact form is handled by a
                free service called <abbr class="hint" title="A free form-to-email service. The messages land in your inbox; no account needed.">FormSubmit</abbr>.
              </span>
            </span>
          </label>
          <label class="host-option">
            <input type="radio" name="host" value="netlify" />
            <span class="host-option__body">
              <span class="host-option__name">Netlify</span>
              <span class="host-option__desc">
                A dedicated <abbr class="hint" title="A hosting platform for simple websites with a generous free tier.">Netlify</abbr>
                account with a built-in contact-form inbox and free custom domains. Needs a
                quick one-time connect.
              </span>
            </span>
          </label>
        </fieldset>
        <div class="start__actions" id="netlify-actions" hidden>
          <a id="btn-netlify" class="btn btn--primary" href="#" aria-disabled="true">
            Connect Netlify
          </a>
          <a class="btn btn--ghost" href="https://app.netlify.com/signup" target="_blank" rel="noopener">
            Create a Netlify account
          </a>
        </div>
        <p id="netlify-connected" class="start__connected" hidden>
          <span class="start__check" aria-hidden="true"></span>Netlify connected.
        </p>
        <p id="pages-note" class="start__connected" hidden>
          <span class="start__check" aria-hidden="true"></span>Publishing to GitHub Pages — no extra account needed.
        </p>
      </ConnectStep>

      <ConnectStep step={3} title="Build your site" state="todo" shape="triangle">
        <p id="provision-intro">
          We'll copy our template from our GitHub to yours, publish it to your chosen host,
          and get you all the links you need to make your site yours. This takes a few
          minutes, please be patient!
        </p>
        <label class="field" for="provision-email">
          <span class="field__label">Email <span class="field__optional">(optional)</span></span>
          <input id="provision-email" type="email" autocomplete="email" inputmode="email"
            placeholder="you@example.com" />
          <span class="field__help">We'll send your live site + editor links here so you don't lose them. Nothing else.</span>
        </label>
        <button id="btn-provision" class="btn btn--accent" type="button">Build my site</button>
        <div id="provision-progress" hidden>
          <ProgressView />
        </div>
        <p id="provision-error" class="start__error" role="alert" hidden></p>
      </ConnectStep>
    </div>
  </section>

  <div id="mobile-gate" class="mobilegate" hidden>
    <div class="mobilegate__card">
      <h2>Set this up on a computer</h2>
      <p>
        Building your portfolio means dragging in photos and arranging your site —
        fiddly, frustrating work on a phone. You'll have a much better time on a
        laptop or desktop.
      </p>
      <p><strong>Open this page on a computer to get started.</strong></p>
      <a class="btn btn--primary" href="/">Back to home</a>
      <button type="button" id="mobile-bypass" class="mobilegate__bypass">Continue anyway — I understand it'll be rough</button>
    </div>
  </div>
</Base>

<script>
  import { ROUTES } from '../config.ts';

  // Steer phone users to a desktop before they start the fiddly setup. The gate
  // is a hard overlay with a deliberately understated bypass; dismissal sticks
  // for the session so a determined artist isn't nagged on every reload.
  (() => {
    const gate = document.getElementById('mobile-gate');
    if (!gate) return;
    const narrow = window.matchMedia('(max-width: 760px)').matches;
    const bypassed = sessionStorage.getItem('easel_mobile_ok') === '1';
    if (narrow && !bypassed) gate.hidden = false;
    document.getElementById('mobile-bypass')?.addEventListener('click', () => {
      sessionStorage.setItem('easel_mobile_ok', '1');
      gate.hidden = true;
    });
  })();

  type Stage = 'repo' | 'site' | 'deploy' | 'admin' | 'cleanup';

  const params = new URLSearchParams(location.search);
  // The worker round-trips this opaque, HMAC-signed value through both OAuth hops.
  const state = params.get('state') ?? sessionStorage.getItem('easel_state') ?? '';
  if (state) sessionStorage.setItem('easel_state', state);

  // Record progress from the worker's return hop. These flags give the UI an
  // instant, optimistic render; the worker is the real source of truth and we
  // reconcile against it below (see reconcile()).
  // 'netlify' = GitHub just connected; 'provision' = Netlify just connected.
  const returnedStep = params.get('step');
  if (returnedStep === 'netlify' || returnedStep === 'provision') {
    sessionStorage.setItem('easel_gh', '1');
    const login = params.get('login');
    if (login) sessionStorage.setItem('easel_gh_login', login);
  }
  if (returnedStep === 'provision') sessionStorage.setItem('easel_nf', '1');

  // The worker reports OAuth failures by redirecting to /start?error=<reason>.
  // Surface them instead of leaving the artist staring at a button that "did
  // nothing." A failed hop means that account isn't connected — clear its flag.
  const errorReason = params.get('error');
  const ERROR_COPY: Record<string, string> = {
    github_state: "We couldn't verify that GitHub sign-in. Please connect GitHub again.",
    github_required: 'Connect GitHub first, then choose where to publish.',
    netlify_state: "We couldn't verify that Netlify sign-in. Please connect Netlify again.",
  };
  if (errorReason) {
    if (errorReason.startsWith('github')) {
      sessionStorage.removeItem('easel_gh');
      sessionStorage.removeItem('easel_gh_login');
    }
    if (errorReason.startsWith('netlify')) sessionStorage.removeItem('easel_nf');
  }

  // Drop the signed state + step + error out of the address bar now that they're
  // captured, so a refresh doesn't replay them.
  if (returnedStep || params.get('state') || errorReason) {
    history.replaceState(null, '', location.pathname);
  }

  const stepEls = Array.from(document.querySelectorAll<HTMLElement>('.step'));
  const setStepState = (n: number, s: 'todo' | 'active' | 'done') => {
    const el = stepEls.find((e) => e.dataset.step === String(n));
    if (!el) return;
    el.classList.remove('step--todo', 'step--active', 'step--done');
    el.classList.add(`step--${s}`);
    el.setAttribute('aria-current', s === 'active' ? 'step' : 'false');
    const badge = el.querySelector<HTMLElement>('[data-role="badge"]');
    if (badge) badge.textContent = s === 'done' ? 'Done' : s === 'active' ? 'Now' : 'Next';
  };

  type HostId = 'netlify' | 'github-pages';
  const DEFAULT_HOST: HostId = 'github-pages';
  const getProvider = (): HostId =>
    (sessionStorage.getItem('easel_provider') as HostId) || DEFAULT_HOST;
  const setProvider = (h: HostId) => sessionStorage.setItem('easel_provider', h);

  const netlifyBtn = document.querySelector<HTMLAnchorElement>('#btn-netlify');
  const hostRadios = Array.from(
    document.querySelectorAll<HTMLInputElement>('#host-picker input[name="host"]'),
  );
  const pagesNote = document.querySelector<HTMLElement>('#pages-note');
  const provisionBtn = document.querySelector<HTMLButtonElement>('#btn-provision');
  const progressWrap = document.querySelector<HTMLElement>('#provision-progress');
  const errorEl = document.querySelector<HTMLElement>('#provision-error');
  const githubActions = document.querySelector<HTMLElement>('#github-actions');
  const netlifyActions = document.querySelector<HTMLElement>('#netlify-actions');
  const githubConnected = document.querySelector<HTMLElement>('#github-connected');
  const githubLoginEl = document.querySelector<HTMLElement>('#github-login');
  const netlifyConnected = document.querySelector<HTMLElement>('#netlify-connected');
  const startOverWrap = document.querySelector<HTMLElement>('#start-over-wrap');
  const startOverBtn = document.querySelector<HTMLButtonElement>('#btn-start-over');
  const connectError = document.querySelector<HTMLElement>('#connect-error');

  // Point the Netlify connect button at the worker, carrying the session state so
  // the worker attaches the Netlify token to the same run. No site name needed —
  // Netlify assigns a unique address, and the artist can add a custom domain later.
  const enableNetlifyBtn = () => {
    if (!netlifyBtn) return;
    const url = new URL(ROUTES.authNetlify);
    url.searchParams.set('state', state);
    netlifyBtn.href = url.toString();
    netlifyBtn.setAttribute('aria-disabled', 'false');
  };

  // Clear all per-run progress and return to a fresh /start.
  const resetFlow = () => {
    ['easel_state', 'easel_gh', 'easel_gh_login', 'easel_nf'].forEach((k) =>
      sessionStorage.removeItem(k),
    );
  };
  startOverBtn?.addEventListener('click', () => {
    resetFlow();
    location.replace(location.pathname);
  });

  // Paint the whole connect UI from a known connection state. Idempotent — it
  // sets every element for both the connected and not-connected case, so it can
  // run optimistically first and then again with the worker's authoritative
  // answer without leaving stale bits behind.
  const render = (gh: boolean, nf: boolean, login: string | null) => {
    startOverWrap?.toggleAttribute('hidden', !(gh || nf));

    // Step 1 — GitHub
    setStepState(1, gh ? 'done' : 'active');
    githubActions?.toggleAttribute('hidden', gh);
    githubConnected?.toggleAttribute('hidden', !gh);
    if (githubLoginEl) githubLoginEl.textContent = gh && login ? ` as @${login}` : '';

    // Step 2 — choose where to publish. GitHub Pages needs no second connection
    // (it publishes with the GitHub token already in hand); Netlify needs its OAuth.
    const provider = getProvider();
    const usingPages = provider === 'github-pages';
    const hostReady = usingPages || nf;
    // Keep the radios in sync with the stored choice (e.g. after a round-trip).
    hostRadios.forEach((r) => { r.checked = r.value === provider; });

    pagesNote?.toggleAttribute('hidden', !usingPages);
    netlifyConnected?.toggleAttribute('hidden', !(provider === 'netlify' && nf));
    // Show the Netlify connect button only when Netlify is chosen and not yet linked.
    netlifyActions?.toggleAttribute('hidden', usingPages || nf);

    if (gh && hostReady) {
      setStepState(2, 'done');
    } else if (gh && !usingPages) {
      setStepState(2, 'active');
      enableNetlifyBtn();
    } else {
      setStepState(2, gh ? 'active' : 'todo');
      netlifyBtn?.setAttribute('aria-disabled', 'true');
    }

    // Step 3 — Build (only once GitHub is connected and a host is ready).
    const buildReady = gh && hostReady;
    setStepState(3, buildReady ? 'active' : 'todo');
    if (provisionBtn) provisionBtn.disabled = !buildReady;
  };

  const showConnectError = (reason: string) => {
    if (!connectError) return;
    connectError.textContent =
      ERROR_COPY[reason] ?? 'Something went wrong connecting that account. Please try again.';
    connectError.removeAttribute('hidden');
  };

  // Keep the "site" progress row's wording matched to the chosen host.
  const siteLabel = document.querySelector<HTMLElement>(
    '.progress__item[data-stage="site"] .progress__label',
  );
  const updateSiteLabel = () => {
    if (!siteLabel) return;
    siteLabel.textContent =
      getProvider() === 'github-pages'
        ? 'Enabling GitHub Pages and wiring your contact form'
        : 'Setting up your Netlify site and contact form';
  };

  // Repaint from the current stored flags (used after a host-choice change).
  const repaint = () => {
    render(
      sessionStorage.getItem('easel_gh') === '1',
      sessionStorage.getItem('easel_nf') === '1',
      sessionStorage.getItem('easel_gh_login'),
    );
    updateSiteLabel();
  };

  // Switching host re-paints step 2/3 (and reveals/hides the Netlify connect button).
  hostRadios.forEach((r) =>
    r.addEventListener('change', () => {
      if (r.checked) {
        setProvider(r.value as HostId);
        repaint();
      }
    }),
  );

  // Optimistic first paint from the just-returned step / stored flags, so the
  // page is responsive immediately even before the worker confirms.
  repaint();
  if (errorReason) showConnectError(errorReason);

  // Reconcile against the worker — the real source of truth. KV tokens expire
  // after 10 minutes, and sessionStorage flags can outlive them (reload, back
  // button, session-restore). If the worker says a token is gone, downgrade the
  // UI so we never claim "connected" when a build would fail.
  const reconcile = async () => {
    if (!state) {
      // No run in progress — make sure nothing stale is showing.
      resetFlow();
      render(false, false, null);
      return;
    }
    try {
      const url = new URL(ROUTES.session);
      url.searchParams.set('state', state);
      const res = await fetch(url.toString());
      if (!res.ok) return; // keep the optimistic view; transient worker hiccup
      const s = (await res.json()) as { github?: boolean; netlify?: boolean; githubLogin?: string | null };
      const gh = !!s.github;
      const nf = !!s.netlify;
      // Persist the corrected truth so the next paint/refresh starts accurate.
      if (gh) sessionStorage.setItem('easel_gh', '1');
      else { sessionStorage.removeItem('easel_gh'); sessionStorage.removeItem('easel_gh_login'); }
      if (nf) sessionStorage.setItem('easel_nf', '1');
      else sessionStorage.removeItem('easel_nf');
      if (s.githubLogin) sessionStorage.setItem('easel_gh_login', s.githubLogin);
      render(gh, nf, s.githubLogin ?? sessionStorage.getItem('easel_gh_login'));
    } catch {
      // Network error — leave the optimistic view in place.
    }
  };
  void reconcile();

  // ---- Provisioning ----
  const STAGES: Stage[] = ['repo', 'admin', 'site', 'deploy', 'cleanup'];

  const markStage = (stage: Stage, s: 'pending' | 'active' | 'done' | 'error') => {
    const li = document.querySelector<HTMLElement>(`.progress__item[data-stage="${stage}"]`);
    if (!li) return;
    li.dataset.state = s;
    const sr = li.querySelector<HTMLElement>('.progress__state');
    if (sr) sr.textContent = s;
  };

  async function runProvision() {
    if (!provisionBtn) return;
    provisionBtn.disabled = true;
    provisionBtn.textContent = 'Building…';
    progressWrap?.removeAttribute('hidden');
    errorEl?.setAttribute('hidden', '');

    try {
      // POST /provision kicks off the 5-step run on the worker. The worker may
      // return the final result directly, or { jobId } that we poll. We support
      // both: if a jobId comes back, poll GET /provision?job=...; otherwise the
      // body is the terminal result.
      const emailInput = document.querySelector<HTMLInputElement>('#provision-email');
      const email = emailInput?.value.trim() || undefined;
      const res = await fetch(ROUTES.provision, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ state, email, provider: getProvider() }),
      });
      const data = await res.json().catch(() => ({}));

      if (!res.ok) {
        // Reflect which stage failed, and show the worker's real message.
        if (data.stages) {
          for (const st of STAGES) if (data.stages[st]) markStage(st, data.stages[st]);
        }
        throw new Error(data.message ? `${data.message} (${res.status})` : `Provisioning failed (${res.status})`);
      }

      if (data.jobId) {
        await pollJob(data.jobId);
      } else {
        // Direct result — reflect a completed run in the UI.
        for (const st of STAGES) markStage(st, 'done');
        finish(data);
      }
    } catch (err) {
      showError(err instanceof Error ? err.message : 'Something went wrong. Please try again.');
    }
  }

  // If a run failed partway, the worker still returns links to whatever it created
  // (repo, site) so the artist isn't left at a dead end. Render them under the error.
  function showRecoveryLinks(data: { repoUrl?: string; siteUrl?: string; adminUrl?: string }) {
    if (!errorEl || (!data.repoUrl && !data.siteUrl)) return;
    const links: string[] = [];
    if (data.siteUrl) links.push(`<a href="${data.siteUrl}">your site</a>`);
    if (data.adminUrl) links.push(`<a href="${data.adminUrl}">your editor</a>`);
    if (data.repoUrl) links.push(`<a href="${data.repoUrl}">your files on GitHub</a>`);
    const p = document.createElement('p');
    p.className = 'start__recovery';
    p.innerHTML = `What got set up so far: ${links.join(', ')}. You can retry, or pick up from there.`;
    errorEl.insertAdjacentElement('afterend', p);
  }

  async function pollJob(jobId: string) {
    // Simple polling loop. The worker reports the current stage + status until
    // it reaches a terminal 'done' or 'error' state. (SSE is a future upgrade.)
    // The window is generous because the deploy stage now waits for Netlify's first
    // build to actually finish — the worker hands that wait off to these polls, and
    // a cold Astro build can run a few minutes. ~200 × 2.5s ≈ 8 min of headroom.
    const url = new URL(ROUTES.provision);
    url.searchParams.set('job', jobId);

    for (let i = 0; i < 200; i++) {
      await new Promise((r) => setTimeout(r, 2500));
      const res = await fetch(url.toString());
      if (!res.ok) continue;
      const data = await res.json();

      // data.stages: { repo: 'done', site: 'active', ... }
      if (data.stages) {
        for (const st of STAGES) {
          if (data.stages[st]) markStage(st, data.stages[st]);
        }
      }
      if (data.status === 'done') return finish(data);
      if (data.status === 'error') {
        showError(data.message ?? 'Provisioning failed.');
        return showRecoveryLinks(data);
      }
    }
    showError('This is taking longer than expected. Your site may still be building, so check back shortly.');
  }

  function finish(data: {
    siteUrl?: string;
    adminUrl?: string;
    repoUrl?: string;
    netlifyName?: string;
    dashboardSlug?: string;
    provider?: string;
    warning?: string;
  }) {
    resetFlow();
    const done = new URL('/start/done/', location.origin);
    if (data.siteUrl) done.searchParams.set('site', data.siteUrl);
    if (data.adminUrl) done.searchParams.set('admin', data.adminUrl);
    if (data.repoUrl) done.searchParams.set('repo', data.repoUrl);
    if (data.netlifyName) done.searchParams.set('netlify', data.netlifyName);
    if (data.dashboardSlug) done.searchParams.set('slug', data.dashboardSlug);
    if (data.provider) done.searchParams.set('host', data.provider);
    if (data.warning) done.searchParams.set('warning', data.warning);
    location.assign(done.toString());
  }

  function showError(msg: string) {
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.removeAttribute('hidden');
    }
    const active = document.querySelector<HTMLElement>('.progress__item[data-state="active"]');
    if (active) active.dataset.state = 'error';
    if (provisionBtn) {
      provisionBtn.disabled = false;
      provisionBtn.textContent = 'Try again';
    }
  }

  provisionBtn?.addEventListener('click', runProvision);
</script>

<style>
  .start__inner { max-width: 760px; }
  .start__head { margin-bottom: var(--space-6); }
  .start__sub { font-size: 1.125rem; max-width: 54ch; color: var(--c-stone); }
  .start__over { font-size: 0.9375rem; color: var(--c-stone); margin: 0; }
  .linklike {
    font: inherit;
    color: var(--c-blue);
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .start__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center; }
  .start__visually-hidden {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
  .host-picker {
    border: 0; padding: 0; margin: 0 0 var(--space-4);
    display: grid; gap: var(--space-3);
  }
  .host-option {
    display: flex; gap: var(--space-3); align-items: flex-start;
    padding: var(--space-3);
    border: var(--border);
    border-radius: var(--radius);
    background: var(--c-white);
    cursor: pointer;
  }
  .host-option:has(input:checked) {
    border-left: var(--border-thick);
    border-left-color: var(--c-blue);
    background: var(--c-paper);
  }
  .host-option:has(input:focus-visible) { outline: 2px solid var(--c-blue); outline-offset: 2px; }
  .host-option input { margin-top: 0.25rem; flex: none; }
  .host-option__body { display: flex; flex-direction: column; gap: var(--space-1); }
  .host-option__name { font-family: var(--font-display); font-weight: 700; color: var(--c-ink); }
  .host-option__tag {
    display: inline-block; margin-left: var(--space-2);
    font-family: var(--font-body); font-size: 0.6875rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--c-white); background: var(--c-blue);
    padding: 0.1rem 0.4rem; border-radius: var(--radius);
    vertical-align: middle;
  }
  .host-option__desc { color: var(--c-stone); font-size: 0.9375rem; }
  .start__hint { color: var(--c-stone); font-size: 0.9375rem; margin: var(--space-3) 0 0; }
  .start__error {
    margin: var(--space-3) 0 0;
    border: var(--border);
    border-left: var(--border-thick);
    border-left-color: var(--c-red);
    background: var(--c-white);
    padding: var(--space-3);
    color: var(--c-ink);
  }
  .field { display: block; margin-bottom: var(--space-4); }
  .field__label { display: block; font-family: var(--font-display); font-weight: 700; margin-bottom: var(--space-2); }
  .field input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 1.0625rem;
    padding: 0.625rem 0.75rem;
    border: var(--border);
    border-radius: var(--radius);
    background: var(--c-white);

---
import Base from '../../layouts/Base.astro';
import EaselMark from '../../components/EaselMark.astro';

// Success screen. The live site + admin URLs are passed as query params by the
// provisioning flow (?site=...&admin=...). We read them on the client because
// this is a static page.
---

<Base title="Your site is live · Easel" description="Your Easel portfolio is live. Start adding your work.">
  <section class="section done">
    <div class="container done__inner">
      <div class="done__mark"><EaselMark size={88} title="" /></div>
      <h1>Your portfolio is live</h1>
      <p class="done__sub">
        Easel created your repository, built your site, and set up your editor.
        Everything from here lives on accounts you own.
      </p>

      <p id="done-warning" class="done__warning" role="status" hidden></p>

      <div class="done__actions">
        <a id="link-site" class="btn btn--primary" href="#" target="_blank" rel="noopener">
          View your live site
        </a>
        <a id="link-admin" class="btn btn--accent" href="#" target="_blank" rel="noopener">
          Edit your site (/admin)
        </a>
      </div>

      <ol class="done__next" role="list">
        <li><strong>Open your editor</strong> and sign in with the GitHub account you connected. It walks you through naming your site and choosing a look.</li>
        <li><strong>Add a few works:</strong> drag in photos, give them titles and prices.</li>
        <li><strong>Hit save.</strong> Each save publishes a fresh version of your site on its own.</li>
      </ol>

      <p class="done__help">
        Want a custom domain like your-name.com? Add it from
        <a id="link-domain" href="#" target="_blank" rel="noopener">your Netlify domain settings</a>
        whenever you're ready. Our <a href="/custom-domain/">step-by-step domain guide</a> walks
        you through it.
      </p>

      <div class="done__own">
        <h2 class="done__own-title">It's yours to keep</h2>
        <p>
          Your whole site (every image, page, and setting) lives in
          <a id="link-repo" href="#" target="_blank" rel="noopener">your own GitHub repository</a>.
          Easel doesn't host it and can't lock you in. If you ever want to move hosts or hand it
          to a developer, the <a href="/own-your-site/">take-it-with-you guide</a> shows you how.
        </p>
      </div>
    </div>
  </section>
</Base>

<script>
  import { domainSetupUrl, slugFromSite, writeDeploy, type HostId } from '../../deploy';

  const params = new URLSearchParams(location.search);
  const site = params.get('site');
  const admin = params.get('admin');
  const repo = params.get('repo');
  const provider: HostId = params.get('host') === 'github-pages' ? 'github-pages' : 'netlify';
  const netlify = params.get('netlify') ?? params.get('slug') ?? slugFromSite(site);
  const warning = params.get('warning');

  const siteLink = document.querySelector<HTMLAnchorElement>('#link-site');
  const adminLink = document.querySelector<HTMLAnchorElement>('#link-admin');
  const repoLink = document.querySelector<HTMLAnchorElement>('#link-repo');
  const domainLink = document.querySelector<HTMLAnchorElement>('#link-domain');
  const warnEl = document.querySelector<HTMLElement>('#done-warning');

  if (site && siteLink) siteLink.href = site;
  else siteLink?.setAttribute('aria-disabled', 'true');

  // Default admin URL is the live site + /admin if not explicitly provided.
  const adminHref = admin ?? (site ? `${site.replace(/\/$/, '')}/admin/` : null);
  if (adminHref && adminLink) adminLink.href = adminHref;
  else adminLink?.setAttribute('aria-disabled', 'true');

  // Link the repo if we have it; otherwise point at the user's GitHub repos list.
  if (repoLink) repoLink.href = repo ?? 'https://github.com/?tab=repositories';

  // Remember this deployment so the domain guide (and any later visit) can pick up
  // where the artist left off instead of giving generic, un-personalized steps.
  const rec = {
    site: site ?? '',
    admin: adminHref ?? undefined,
    repo: repo ?? undefined,
    provider,
    netlify: netlify ?? undefined,
    at: new Date().toISOString(),
  };

  // Deep-link straight into where this host sets up a custom domain, and label the
  // link for the host so the copy isn't Netlify-specific on a Pages site.
  if (domainLink) {
    domainLink.href = domainSetupUrl(rec) ?? '#';
    domainLink.textContent =
      provider === 'github-pages' ? 'your GitHub Pages settings' : 'your Netlify domain settings';
  }

  if (site) writeDeploy(rec);

  // Surface a non-fatal note from provisioning (e.g. auto-publish couldn't be
  // confirmed) so the artist knows what to check, without it reading as a failure.
  if (warning && warnEl) {
    warnEl.textContent = warning;
    warnEl.removeAttribute('hidden');
  }
</script>

<style>
  .done__inner { max-width: 680px; text-align: center; margin-inline: auto; }
  .done__mark {
    display: inline-flex;
    border: var(--border-thick);
    background: var(--c-white);
    padding: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .done__sub { font-size: 1.25rem; color: var(--c-stone); max-width: 48ch; margin-inline: auto; }
  .done__actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
    margin-block: var(--space-5);
  }
  .done__next {
    text-align: left;
    list-style: none;
    counter-reset: step;
    margin: var(--space-5) auto 0;
    padding: 0;
    max-width: 520px;
    display: grid;
    gap: var(--space-3);
  }
  .done__next li {
    counter-increment: step;
    border: var(--border);
    background: var(--c-white);
    padding: var(--space-3) var(--space-3) var(--space-3) var(--space-6);
    position: relative;
  }
  .done__next li::before {
    content: counter(step);
    position: absolute;
    left: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    width: 28px; height: 28px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--c-blue); color: var(--c-white);
    font-family: var(--font-display); font-weight: 800;
    border: var(--border);
  }
  .done__help { margin-top: var(--space-5); color: var(--c-stone); }
  .done__warning {
    margin: var(--space-4) auto 0;
    max-width: 520px;
    text-align: left;
    border: var(--border);
    border-left: var(--border-thick);
    border-left-color: var(--c-yellow);
    background: var(--c-white);
    padding: var(--space-3);
    color: var(--c-ink);
    font-size: 0.9375rem;
  }
  .done__own {
    margin-top: var(--space-6);
    border-top: var(--border);
    padding-top: var(--space-5);
    text-align: left;
    max-width: 520px;
    margin-inline: auto;
    color: var(--c-stone);
  }
  .done__own-title { font-size: 1.125rem; margin: 0 0 var(--space-2); }
  .btn[aria-disabled='true'] { opacity: 0.5; pointer-events: none; }
</style>
